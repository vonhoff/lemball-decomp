{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 15,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "msvc420",
      "displayName": "MSVC 4.20",
      "generator": "NMake Makefiles",
      "binaryDir": "${sourceDir}/build-msvc420",
      "toolchainFile": "${sourceDir}/cmake/msvc420-toolchain.cmake",
      "cacheVariables": {
        "LEMBALL_ENABLE_WIN32": "ON"
      }
    },
    {
      "name": "openwatcom-win32",
      "displayName": "Open Watcom 2.x Win32",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-openwatcom",
      "toolchainFile": "${sourceDir}/cmake/openwatcom-toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "LEMBALL_ENABLE_WIN32": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "msvc420",
      "configurePreset": "msvc420"
    },
    {
      "name": "openwatcom-win32",
      "configurePreset": "openwatcom-win32"
    }
  ]
}
